# Verum - Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===
# Access token for API authentication (used by both journal and quotes)
JOURNAL_ACCESS_TOKEN=your-secret-token-here

# === OPTIONAL - Database Paths ===
# Path to the journal SQLite database (default: journal.db)
JOURNAL_DB_PATH=journal.db

# Path to the quotes SQLite database (default: /home/Marcuu/app/data/quotes.db)
QUOTES_DB_PATH=quotes.db

# === OPTIONAL - CORS Configuration ===
# Comma-separated list of allowed origins (empty = allow all)
JOURNAL_ALLOWED_ORIGIN=https://yourdomain.com,http://localhost:3000

# === OPTIONAL - Public Access ===
# Allow unauthenticated GET requests (default: false)
JOURNAL_PUBLIC_READ=false

# === OPTIONAL - Rate Limiting ===
# Rate limit window in seconds (default: 300)
JOURNAL_RATE_WINDOW=300

# Max read requests per window (default: 120)
JOURNAL_RATE_READ=120

# Max write requests per window (default: 20)
JOURNAL_RATE_WRITE=20

# === OPTIONAL - Quotes Configuration ===
# Separate token for quotes API (falls back to JOURNAL_ACCESS_TOKEN)
QUOTES_ACCESS_TOKEN=

# Score threshold for "core" quotes (default: 3)
QUOTES_CORE_THRESHOLD=3

# Days to avoid showing recently seen quotes (default: 14)
QUOTES_AVOID_DAYS=14

# === OPTIONAL - Server ===
# Port to run on (default: 8080)
PORT=8080
