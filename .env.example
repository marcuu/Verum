# Verum — Environment Variables
# Copy to .env.local for local dev; set the same vars in the Vercel dashboard.

# === Supabase (server) ===
# Project URL and keys from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://mvedaurabbwemlqdzwml.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# SECRET — service role key. Bypasses RLS. Server-only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Auth ===
# Shared access token gating the app (replaces the old JOURNAL_ACCESS_TOKEN).
JOURNAL_ACCESS_TOKEN=your-secret-token-here

# Allow unauthenticated GET requests (default: false)
JOURNAL_PUBLIC_READ=false

# === Quotes config (optional) ===
# Score at/above which a quote is "core" (default: 3)
QUOTES_CORE_THRESHOLD=3
# Days to avoid re-showing a recently picked quote (default: 14)
QUOTES_AVOID_DAYS=14

# === Life calendar (optional, public/client) ===
# Date of birth and life expectancy in years for the calendar grid.
NEXT_PUBLIC_DOB=1993-12-19
NEXT_PUBLIC_LIFE_YEARS=108
